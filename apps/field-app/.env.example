# Absolute URL to the OpenMRS instance. Omit in dev (Vite proxy handles it).
# VITE_OPENMRS_BASE_URL=https://openmrs.example.org/openmrs

# Location UUID for patient identifiers and encounters.
# Default: Outpatient Clinic in the OpenMRS 3 reference application.
# VITE_LOCATION_UUID=44c3efb0-2583-4c80-a79e-1f756a03c0a1

# GCS Total concept UUID.
# Default: manually created in the reference instance.
# If the full CIEL dictionary is loaded, use CIEL 162643:
# VITE_GCS_CONCEPT_UUID=162643AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
